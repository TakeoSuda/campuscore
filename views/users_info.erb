<% @users.each do |user| %>
    <p>ID: <%= user['id'] %></p>
    <p>カナ: <%= user['name_kana'] %></p>
    <p>名前: <%= user['name'] %></p>
    <p>メールアドレス: <%= user['email'] %></p>
    <p>学校: <%= user['school'] %></p>
    <p>学年: <%= user['grade'] %></p>
    <p>第１志望校: <%= user['desired_school'] %></p>
    <p>学部: <%= user['faculty'] %></p>
    <p>学科: <%= user['department'] %></p>
    <p>第２志望校: <%= user['second_desired_school'] %></p>
    <p>学部: <%= user['second_desired_faculty'] %></p>
    <p>学科: <%= user['second_desired_department'] %></p>
    <p>英検取得済級: <%= user['eiken_level'] %></p>
    <p>英検取得希望級: <%= user['desired_eiken_level'] %></p>
    <p>共通テスト目標点R: <%= user['target_ct_reading'] %></p>
    <p>共通テスト目標点L: <%= user['target_ct_listening'] %></p>
    <p>共通テスト最終点R: <%= user['last_ct_reading'] %></p>
    <p>共通テスト最終点L: <%= user['last_ct_listening'] %></p>
    <p>得意な教科: <%= user['strong_subject'] %></p>
    <p>苦手な教科: <%= user['weak_subject'] %></p>
    <p>趣味: <%= user['hobby'] %></p>
    <p>部活: <%= user['club'] %></p>
    <p>やりたい職業: <%= user['desired_job'] %></p>
    <p>夢: <%= user['dream'] %></p>
    <p>抱負: <%= user['resolution'] %></p>
    <p>相談したいこと: <%= user['consult'] %></p>
    <p>悩み: <%= user['worry'] %></p>
    <p>授業に対する希望: <%= user['request_for_class'] %></p>
    <p>推薦希望受験の有無: <% if user['recommend_exam'] == 't' %>希望する
    <% else %>希望しない</p>
    <% end %>
    <p>作成日時: <%= user['created_at'] %></p>
    <p>更新日時: <%= user['updated_at'] %></p>
    <h1>学習計画</h1>
    <% user['plans'].each do |plan| %>
        <p>教科: <%= plan['subject'] %></p>
        <p>教材: <%= plan['material'] %></p>
        <p>開始予定日: <%= plan['start_date'] %></p>
        <p>終了予定日: <%= plan['end_date'] %></p>
        <p>何周するか: <%= plan['laps'] %></p>
        <p>何周したか: <%= plan['completed_laps'] %></p>
        <p>目的: <%= plan['purpose'] %></p>
        <p>進み具合: 
            <% if plan['status'] == 'in_progress' %>
                進行中
            <% elsif plan['status'] == 'not_started' %>
                未開始
            <% else %>
                完了
            <% end %>
        </p>
    <% end %>
    <h1>勉強日記</h1>
    <% user['diaries'].each do |diary| %>
        <p>日付: <%= diary['date'] %></p>
        <p>内容: <%= diary['content'] %></p>
    <% end %>
    <h1>面談記録</h1>
    <% user['consults'].each do |consult| %>
        <p>日付: <%= consult['date'] %></p>
        <p>内容: <%= consult['content'] %></p>
    <% end %>
    <hr>

<% end %>

<a href="/">戻る</a>

