<h1>勉強日記</h1>
<form action="/diary/new" method="post">
<div>
<label for="date">日付:</label>
<input type="date" name="date" id="date" placeholder="日付" required>
</div>
<div>
<label for="content">内容:</label>
<textarea name="content" id="content" rows="4" cols="50" placeholder="内容" required></textarea>
</div>
<input type="submit" value="保存">
</form>

<% @diary_entries.each do |entry| %>
<div>
<p>日付：<%= entry["date"] %></p>
<p>内容：<%= entry["content"] %></p>
</div>
<% end %>

<div>
<a href="/mypage">マイページに戻る</a>
</div>