<h1><%= @test_name %>のテスト結果</h1>
<p>あなたの正解数は <span style="font-weight: bold; color: green;"><%= @correct_count %> 問</span>です！</p>
<p>正解率は <span style="font-weight: bold; color: green;"><%= @accuracy_rate %></span> % です！</p>
<p>正解した問題:</p>
<div style="list-style: none; padding-left: 0;"> <!-- 念のため大枠の余白をリセット -->
  <% @correct_answers.each do |answer| %>
    <!-- 💡 問題ごとに一つのまとまり（ブロック）にする -->
    <div style="margin-bottom: 20px;">
      <div><strong>問題番号: <%= answer["id"] %></strong></div>
      <div><%= answer["question_text"] %></div>
      <div>①<%= answer["option_1"] %></div>
      <div>②<%= answer["option_2"] %></div>
      <div>③<%= answer["option_3"] %></div>
      <div>④<%= answer["option_4"] %></div>
      <div style="color: green; font-weight: bold;">あなたの回答: <%= answer["selected_option"] %></div>
      <div style="color: green; font-weight: bold;">正解: <%= answer["correct_option"] %></div>
      <div style="color: #666; font-size: 0.9em;">
        回答日時：<%= Time.parse(answer["answered_at"]).strftime("%Y-%m-%d %H:%M") %>
      </div>
      <hr style="border: 0; border-top: 1px solid #ccc; margin-top: 15px;">
    </div>
  <% end %>
</div>

<p>不正解だった問題:</p>
<div style="list-style: none; padding-left: 0;">
  <% @wrong_answers.each do |answer| %>
    <!-- 問題ごとに一つのまとまり（ブロック）にする -->
    <div style="margin-bottom: 20px;">
      <div><strong>問題番号: <%= answer["id"] %></strong></div>
      <div><%= answer["question_text"] %></div>
      <div>①<%= answer["option_1"] %></div>
      <div>②<%= answer["option_2"] %></div>
      <div>③<%= answer["option_3"] %></div>
      <div>④<%= answer["option_4"] %></div>
      
      <!-- 💡 間違えた問題なので、赤系（#d9534fなど）にして視認性をアップ -->
      <div style="color: #d9534f; font-weight: bold;">あなたの回答: <%= answer["selected_option"] %></div>
      <div style="color: green; font-weight: bold;">正解: <%= answer["correct_option"] %></div>
      
      <div style="color: #666; font-size: 0.9em;">
        回答日時：<%= Time.parse(answer["answered_at"]).strftime("%Y-%m-%d %H:%M") %>
      </div>
      <hr style="border: 0; border-top: 1px solid #ccc; margin-top: 15px;">
    </div>
  <% end %>
</div>

<a href="/mypage">マイページに戻る</a>
