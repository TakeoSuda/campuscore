<div style="border: 1px solid #ccc; padding: 10px; margin-bottom: 20px;">
        <h1><%= @user['name'] %>さんの情報</h1>
        <% if @user['avatar'] %>
            <img src="<%= @user['avatar'] %>" alt="プロフィール画像" 
            class="profile-avatar"
            style="max-width: 150px; max-height: 150px; border: 1px solid #ccc; border-radius: 15px; box-shadow: 0 0 10px rgba(0,0,0,0.1); object-fit: cover; transition: transform 0.3s ease;"
            >
        <% end %>
        <p>カナ: <%= @user['name_kana'] %></p>
        <p>ID: <%= @user['id'] %></p>
        <p>メールアドレス: <%= @user['email'] %></p>
        <p>所属校舎: <%= @user['campus'] %></p>
        <p>学校: <%= @user['school'] %></p>
        <p>学年: <%= @user['grade'] %></p>
        <p>第１志望校: <%= @user['desired_school'] %></p>
        <p>学部: <%= @user['faculty'] %></p>
        <p>学科: <%= @user['department'] %></p>
        <p>第２志望校: <%= @user['second_desired_school'] %></p>
        <p>学部: <%= @user['second_desired_faculty'] %></p>
        <p>学科: <%= @user['second_desired_department'] %></p>
        <p>第３志望校: <%= @user['third_desired_school'] %></p>
        <p>学部: <%= @user['third_desired_faculty'] %></p>
        <p>学科: <%= @user['third_desired_department'] %></p>
        <p>英検取得済級: <%= @user['eiken_level'] %></p>
        <p>英検取得希望級: <%= @user['desired_eiken_level'] %></p>
        <p>共通テスト目標点R: <%= @user['target_ct_reading'] %></p>
        <p>共通テスト目標点L: <%= @user['target_ct_listening'] %></p>
        <p>共通テスト最終点R: <%= @user['last_ct_reading'] %></p>
        <p>共通テスト最終点L: <%= @user['last_ct_listening'] %></p>
        <p>得意な教科: <%= @user['strong_subject'] %></p>
        <p>苦手な教科: <%= @user['weak_subject'] %></p>
        <p>趣味: <%= @user['hobby'] %></p>
        <p>部活: <%= @user['club'] %></p>
        <p>やりたい職業: <%= @user['desired_job'] %></p>
        <p>夢: <%= @user['dream'] %></p>
        <p>抱負: <%= @user['resolution'] %></p>
        <p>相談したいこと: <%= @user['consult'] %></p>
        <p>悩み: <%= @user['worry'] %></p>
        <p>授業に対する希望: <%= @user['request_for_class'] %></p>
        <p>推薦希望受験の有無: <% if @user['recommend_exam'] == 't' %>希望する
        <% else %>希望しない</p>
        <% end %>
        <p>作成日時: <%= @user['created_at'] %></p>
        <p>更新日時: <%= @user['updated_at'] %></p>
        <div style="border: 1px solid #ccc; padding: 10px; margin-top: 20px;">
            <h1>勉強履歴・勉強計画</h1>
            <% @user['plans'].each do |plan| %>
                <p>教科: <%= plan['subject'] %></p>
                <p>教材: <%= plan['material'] %></p>
                <p>開始予定日: <%= plan['start_date'] %></p>
                <p>終了予定日: <%= plan['end_date'] %></p>
                <p>何周するか: <%= plan['laps'] %></p>
                <p>何周したか: <%= plan['completed_laps'] %></p>
                <p>目的: <%= plan['purpose'] %></p>
                <p>進み具合: 
                    <% if plan['status'] == 'in_progress' %>
                        進行中
                    <% elsif plan['status'] == 'not_started' %>
                        未開始
                    <% else %>
                        完了
                    <% end %>
                </p>
                <hr>
            <% end %>
        </div>
        <div style="border: 1px solid #ccc; padding: 10px; margin-top: 20px;">
            <h1>勉強日記</h1>
            <% @user['diaries'].each do |diary| %>
                <p>日付: <%= diary['date'] %></p>
                <p>内容: <%= diary['content'] %></p>
                <hr>
            <% end %>
        </div>
        <div style="border: 1px solid #ccc; padding: 10px; margin-top: 20px;">
            <h1>面談記録</h1>
            <% @user['consults'].each do |consult| %>
                <p>日付: <%= consult['date'] %></p>
                <p>内容: <%= consult['content'] %></p>
                <hr>
            <% end %>
        </div>
        <div style="border: 1px solid #ccc; padding: 10px; margin-top: 20px;">
            <h1>学習アドバイス</h1>
            <% @user['instructions'].each do |instruction| %>
                <p>日付: <%= instruction['created_at'] %></p>
                <p style="overflow-wrap: break-word;">内容: <%= instruction['content'] %></p>
                <p>返信: <% if instruction['ir_user_id'] == @user['id'] %>
                    <%= instruction['reply_content'] %></p>
                    <% end %>
                <p>返信日時: <% if instruction['ir_user_id'] == @user['id']  %>
                    <%= instruction['reply_created_at'] %></p>
                    <% end %>
                <hr>
            <% end %>
        </div>
        <div style="border: 1px solid #ccc; padding: 10px; margin-top: 20px;">
            <h1>模試・入試結果</h1>
            <% @user['mock_exams'].each do |exam| %>
                <p>受験日: <%= exam['taken_at'] %></p>
                <p>模試の種類: <%= exam['exam_type'] %></p>
                <p>模試の名前: <%= exam['title'] %></p>
                <p>英語リーディング: <%= exam['english_r'] %> 点</p>
                <p>英語リスニング: <%= exam['english_l'] %> 点</p>
                <p>数学ⅠA: <%= exam['math_1a'] %> 点</p>
                <p>数学ⅡBC: <%= exam['math_2bc'] %> 点</p>
                <p>国語: <%= exam['japanese'] %> 点</p>
                <p>物理基礎: <%= exam['physics_basic'] %> 点</p>
                <p>化学基礎: <%= exam['chemistry_basic'] %> 点</p>
                <p>生物基礎: <%= exam['biology_basic'] %> 点</p>
                <p>地学基礎: <%= exam['earth_science_basic'] %> 点</p>
                <p>物理: <%= exam['physics'] %> 点</p>
                <p>化学: <%= exam['chemistry'] %> 点</p>
                <p>生物: <%= exam['biology'] %> 点</p>
                <p>地学: <%= exam['earth_science'] %> 点</p>
                <p>世界史: <%= exam['world_history'] %> 点</p>
                <p>日本史: <%= exam['japanese_history'] %> 点</p>
                <p>地理: <%= exam['geography'] %> 点</p>
                <p>公共倫理: <%= exam['civics_ethics'] %> 点</p>
                <p>公共政経: <%= exam['civics_politics'] %> 点</p>
                <p>地理総合: <%= exam['geography_basic'] %> 点</p>
                <p>歴史総合: <%= exam['history_basic'] %> 点</p>
                <p>公共: <%= exam['civics_basic'] %> 点</p>
                <p>情報: <%= exam['informatics'] %> 点</p>
                <p>結果画像: <% if exam['mock_exam_result_image_url'] %>
                    <img src="<%= exam['mock_exam_result_image_url'] %>" alt="模試結果" style="max-width: 100%;">
                <% end %></p>
                <hr>
            <% end %>
    </div>

<a href="/mypage">戻る</a>
