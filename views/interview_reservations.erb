<h1>面談予約をする</h1>
<form action="/interview_reservations" method="post">
    <% @grouped_slots.each do |campus, slots| %>
        <div>
            <h2><%= campus %>校</h2>
            <% slots.each do |slot| %>
                <div>
                    <input type="radio" name="id" value="<%= slot["id"] %>">
                    <label><%= slot["interview_slot"] %></label>
                </div>
            <% end %>

        </div>
    <% end %>

    <div class="submit-area" style="margin-top: 10px;">
        <input type="submit" value="面談予約をする">
    </div>
</form>
<br>
<h1>自分の面談予約一覧</h1>
<% @my_reservations.each do |slot| %>
  <div>
    <span><%= slot["interview_slot"] %></span>
    <form action="/interview_reservations/cancel" method="post" style="display: inline;">
      <input type="hidden" name="id" value="<%= slot["id"] %>">
      <input type="submit" value="キャンセルする">
    </form>
  </div>
<% end %>

