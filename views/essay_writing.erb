<form action="/essay_writing" method="post" enctype="multipart/form-data" id="upload-form">

    <div>
    <label for="title">提出する自由英作文の情報（どの大学の何年度？英検何級？など）</label>
    </label>
    <input type="text" name="title" id="title" placeholder="自由英作文の情報を入力してください" required style="width: 100%; padding: 8px; margin-top: 5px; border: 1px solid #ccc; border-radius: 4px;">
    </div>
    <div>
    <label for="essay_image">提出する自由英作文の画像</label>
    <input type="file" name="essay_image" id="essay_image" accept="image/*">
    </div>

    <div class="submit-area">
        <input type="submit" id="submit-btn" value="自由英作文を提出する">
        <!-- ぐるぐるアニメーションを表示する隠しエリアを追加 -->
        <div id="loading-spinner" style="display: none; margin-top: 10px;">
            <div class="spinner"></div>
            <p style="color: #666; font-size: 0.9rem;">AIが文字を解析しています。しばらくお待ちください...</p>
        </div>
    </div>
</form>

<script src="/js/file_upload.js"></script>