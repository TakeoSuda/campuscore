source 'https://rubygems.org'

gem 'sinatra'
gem 'pg'      # PostgreSQLを使う場合
gem 'puma'    # Renderで動かすために必須
gem 'bcrypt'  # パスワード用
gem 'rack-flash3' # もしフラッシュメッセージを使うなら
gem 'sinatra-contrib'  # <--- これが必要（cookiesはこの中に含まれている）
gem 'webrick'          # Ruby 3.x系ではこれが必要な場合がある
gem 'pony' # メール送信用（パスワードリセットで必要）
gem 'sinatra-activerecord' # SinatraとActiveRecordを繋ぐ
gem 'rake'                 # データベース操作（作成など）を行うツール
gem 'racksh'
gem 'irb'
gem 'rack-cors' # CORS対策のために追加
gem 'nokogiri'
gem 'selenium-webdriver'
gem 'cloudinary'
gem 'dotenv'
gem 'rtesseract'
gem 'google-cloud-vision'
gem 'ruby-openai'


